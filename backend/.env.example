# Uhodari Backend - Environment Variables Configuration

# ===========================
# FastAPI & Server
# ===========================
# Environment: development, staging, production
ENVIRONMENT=development
DEBUG=True
HOST=0.0.0.0
PORT=8000

# ===========================
# Database
# ===========================
# PostgreSQL connection
DATABASE_URL=postgresql://user:password@localhost:5432/uhodari
# SQLite (for development)
# DATABASE_URL=sqlite:///./test.db

# ===========================
# Redis (for conversation memory & caching)
# ===========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===========================
# LLM Configuration (Required for Chat)
# ===========================
# Get your GROQ API key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxx_your_key_here_xxx

# Alternative LLM providers
# OpenAI
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===========================
# Vector Database (for story context retrieval)
# ===========================
# ChromaDB (local or remote)
VECTOR_DB_PATH=./data/chroma
# VECTOR_DB_HOST=localhost
# VECTOR_DB_PORT=8000

# Weaviate (optional)
# WEAVIATE_URL=http://localhost:8080

# ===========================
# AWS S3 (for media storage)
# ===========================
AWS_ACCESS_KEY_ID=your_aws_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_here
AWS_S3_BUCKET_NAME=uhodari-uploads
AWS_S3_REGION=us-east-1

# ===========================
# Blockchain Configuration
# ===========================
# Ethereum/Blockchain RPC
# BLOCKCHAIN_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
# BLOCKCHAIN_PRIVATE_KEY=your_private_key_here
# CONTRACT_ADDRESS=0x...

# ===========================
# Email Configuration (for notifications)
# ===========================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ===========================
# File Uploads
# ===========================
MAX_UPLOAD_SIZE_MB=500
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=mp3,mp4,wav,m4a,ogg,webm

# ===========================
# CORS Configuration
# ===========================
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# ===========================
# Security
# ===========================
SECRET_KEY=your_super_secret_key_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=168

# ===========================
# Logging
# ===========================
LOG_LEVEL=INFO
